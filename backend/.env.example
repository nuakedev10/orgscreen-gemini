# --- Required ---
# Railway sets PORT automatically; leave blank locally or set to 5001.
PORT=5001

# MongoDB connection string (Atlas or self-hosted).
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# Google Generative AI (Gemini) API key — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# "development" or "production"
NODE_ENV=development

# Comma-separated list of allowed browser origins for CORS.
# Dev defaults (localhost:3000 / :3001) are always allowed.
# Example: https://orgscreen.vercel.app,https://www.orgscreen.com
ALLOWED_ORIGINS=

# --- Email dispatch (Gmail SMTP) ---
# Generate an app password at https://myaccount.google.com/apppasswords
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM_NAME=OrgScreen Hiring
